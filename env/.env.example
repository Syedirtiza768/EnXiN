# ==================================================================
# EnXi ERP — Environment Configuration
# ==================================================================
# Copy this file to .env in the project root:
#
#   cp env/.env.example .env
#
# Then update the passwords below.
# NEVER commit .env to version control.
# ==================================================================

# ---- Site --------------------------------------------------------
SITE_NAME=enxi.localhost
ADMIN_PASSWORD=changeme_admin

# ---- Database ----------------------------------------------------
DB_HOST=db
DB_PORT=3306
DB_ROOT_PASSWORD=changeme_db_root

# ---- HTTP --------------------------------------------------------
# Port exposed on the Docker host (browser → http://localhost:PORT)
HTTP_PORT=8090

# ---- Workers -----------------------------------------------------
GUNICORN_WORKERS=4

# ---- Build configuration (override if needed) --------------------
# PYTHON_VERSION=3.14
# NODE_VERSION=24
# FRAPPE_BRANCH=develop
# PAYMENTS_BRANCH=develop
# ENXI_VERSION=latest
